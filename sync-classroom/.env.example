# Google Classroom OAuth Configuration
# Rename this file to .env and fill in your client credentials and refresh token.

# Get these from the Google Cloud Console for your client "Mudry Gradebook Sync"
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# PORT is optional. Defaults to 3000 if not specified.
# Ensure http://localhost:3000/oauth2callback is added to Authorized Redirect URIs in Cloud Console.
PORT=3000

# The Refresh Token will be outputted to the console when you run node auth.js
# Save the printed value here so the sync scripts can authenticate automatically.
GOOGLE_REFRESH_TOKEN=
