rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is this an authorized Orange USD Teacher?
    function isTeacher() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == 'rmudry@orangeusd.org';
    }

    // --- ROSTER RULES ---
    match /roster/{studentId} {
      allow read, write: if isTeacher();
    }

    // --- STUDENT RESULTS RULES ---
    match /student_results/{docId} {
      allow read, write: if isTeacher();
      
      // Students can only access their own results
      // (Future proofing for when students log in with their own IDs)
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.student_id;
      allow create: if isSignedIn();
    }

    // --- ASSESSMENTS & QUESTIONS ---
    match /assessments/{assessment} {
      allow read: if true; // Students need to read test configs
      allow write: if isTeacher();
    }
    
    match /questions/{questionId} {
      allow read: if true; // Students need to read questions
      allow write: if isTeacher();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
