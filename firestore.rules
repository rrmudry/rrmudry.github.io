rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email != null && (
        request.auth.token.email.lower() == "rmudry@orangeusd.org" ||
        request.auth.token.email.lower() == "ryan.mudry@gmail.com" ||
        request.auth.token.email.lower() == "ryanmudry@gmail.com"
      );
    }

    // Check if the user has an OUSD or approved test email domain
    function isAuthorizedEmail(email) {
      return email.lower().matches('.*@orangeusd\\.org$') ||
             email.lower() == "ryan.mudry@gmail.com" ||
             email.lower() == "ryanmudry@gmail.com";
    }

    // Check if the user matches the student record and is authorized
    function isStudentOwner(studentId) {
      return request.auth != null && 
             request.auth.token.email != null &&
             isAuthorizedEmail(request.auth.token.email) &&
             request.auth.token.email.lower().split('@')[0] == studentId.lower();
    }

    // Global Admin Access
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // 1. Roster Identity Verification
    // The labs (React/Babel) do not use Firebase Auth. They just ask for an ID.
    // We allow ANYONE to `get` a specific student document to verify identity.
    // We DO NOT allow `list` (so students can't download the whole roster).
    match /roster/{studentId} {
      allow get: if true;
    }

    // 2. Student Accommodations
    match /student_accommodations/{studentId} {
      allow get: if true;
    }

    // 3. System Config / Assessments (Needed for dashboards)
    match /system_config/{configDoc} {
      allow read: if true;
    }
    match /assessments/{assessmentId} {
      allow read: if true;
    }
    match /questions/{questionId} {
      allow read: if true;
    }

    // 4. Live Student Results (Nested)
    match /student_results/{assignmentId} {
      allow read: if true;
    }
    match /student_results/{assignmentId}/students/{studentId} {
      allow read, write: if 
        (exists(/databases/$(database)/documents/assessments/$(assignmentId))
          ? isStudentOwner(studentId)
          : true);
    }

    // 5. Archived Flat Results
    match /student_results_archive/{docId} {
      allow read, write: if 
        (request.auth != null 
          ? (isAuthorizedEmail(request.auth.token.email) && docId.lower().matches('^' + request.auth.token.email.lower().split('@')[0] + '_.*'))
          : true);
    }

    // 6. Practice Results (New secure practice collection)
    match /practice_results/{assignmentId} {
      allow read: if true;
    }
    match /practice_results/{assignmentId}/students/{studentId} {
      allow read, write: if request.auth != null && 
                            isAuthorizedEmail(request.auth.token.email) &&
                            request.auth.token.email.lower().split('@')[0] == studentId.lower();
    }

    // 7. Archived Practice Results
    match /practice_results_archive/{docId} {
      allow read, write: if request.auth != null && 
                            isAuthorizedEmail(request.auth.token.email) &&
                            docId.lower().matches('^' + request.auth.token.email.lower().split('@')[0] + '_.*');
    }

    // 8. Private Notes / Journal
    match /notes/{noteId} {
      allow read, write: if request.auth != null && request.auth.token.email.lower() == "rmudry@orangeusd.org";
    }

    // 9. Physics Labs Progress (Speed Calculator, etc.)
    // Each student owns one doc keyed by their email prefix (e.g. "jsmith123")
    match /physics_labs/{studentId} {
      allow read, write: if request.auth != null &&
                            isAuthorizedEmail(request.auth.token.email) &&
                            request.auth.token.email.lower().split('@')[0] == studentId.lower();
    }

    // 10. Bellringers
    match /bellringers/{docId} {
      allow read: if request.auth != null && isAuthorizedEmail(request.auth.token.email);
      allow create, update: if request.auth != null &&
                               isAuthorizedEmail(request.auth.token.email) &&
                               request.resource.data.studentId == request.auth.token.email.lower().split('@')[0];
    }
  }
}
